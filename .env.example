# Frontend environment variables (copy to client/.env or set in Vercel)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Edge Function secrets are configured in Supabase, not in this file:
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# BUNDESAGENTUR_API_KEY
# ADZUNA_APP_ID
# ADZUNA_APP_KEY
# CRON_SECRET
