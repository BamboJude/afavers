# Frontend environment variables (copy to client/.env)
# Required for the React app to talk to Supabase.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Edge Function secrets (configure via `supabase secrets set ...`, not here).
# See VERCEL_SUPABASE_SETUP.md for the full list:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#   BUNDESAGENTUR_API_KEY, ADZUNA_APP_ID, ADZUNA_APP_KEY, CRON_SECRET
