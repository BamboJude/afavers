{
  "name": "afavers",
  "version": "1.0.0",
  "type": "module",
  "description": "afavers — automated job tracker (Supabase + Vercel + React)",
  "private": true,
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "build:client": "npm run build --workspace=client",
    "install:client": "npm install --workspace=client"
  },
  "keywords": [
    "job-tracker",
    "job-search",
    "react",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "eslint": {
      "minimatch": {
        "brace-expansion": "1.1.14"
      }
    }
  }
}
